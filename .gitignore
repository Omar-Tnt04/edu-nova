# ==============================
# Root .gitignore for edu-nova
# Covers both frontend and backend
# ==============================

# ---------- OS ----------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ---------- IDE / Editor ----------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ---------- Python (Backend) ----------
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
.env
.venv/
env/
ENV/
*.egg-info/
*.egg
dist/
build/
*.whl
pip-log.txt
pip-delete-this-directory.txt
.Python
*.manifest
*.spec

# ---------- Node / Next.js (Frontend) ----------
node_modules/
.next/
out/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo
next-env.d.ts

# ---------- Build / Logs ----------
*.log
build_output.log
/coverage/

# ---------- Environment Variables ----------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
# Keep .env.example files (they contain no secrets)
!.env.example

# ---------- Keys / Certificates ----------
*.pem
*.key
*.crt

# ---------- Vercel ----------
.vercel

# ---------- Misc ----------
*.bak
*.tmp
*.temp
