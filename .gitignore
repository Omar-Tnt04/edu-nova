# ==============================
# EduNova Root .gitignore
# Next.js + FastAPI + AI pipeline
# ==============================

# --------------------------------------------------
# OS Files
# --------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --------------------------------------------------
# IDE / Editor
# --------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# --------------------------------------------------
# Python
# --------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
*.whl
*.manifest
*.spec

# Python environments
.venv/
venv/
env/
ENV/

# Python cache
.pip-cache/
.pytest_cache/
.mypy_cache/

# Build artifacts
build/
dist/

# --------------------------------------------------
# Node / Next.js
# --------------------------------------------------
node_modules/
.next/
out/
.pnp
.pnp.*
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo
next-env.d.ts

# Yarn
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --------------------------------------------------
# Environment Variables
# --------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production
.env.production.local

# keep example env files
!.env.example

# --------------------------------------------------
# Logs / Coverage
# --------------------------------------------------
*.log
build_output.log
coverage/

# --------------------------------------------------
# Certificates / Keys
# --------------------------------------------------
*.pem
*.key
*.crt

# --------------------------------------------------
# Runtime Data (AI / Retrieval)
# --------------------------------------------------

# vector databases
pipeline/data/
tutor_engine/data/

# chroma / embeddings
chroma/
vector_index/

# uploaded PDFs
uploads/

# session state
state/

# --------------------------------------------------
# Temporary files
# --------------------------------------------------
*.bak
*.tmp
*.temp
.tmp/
.cache/

# --------------------------------------------------
# Installers / binaries
# --------------------------------------------------
*.exe
*.msi
*.dmg
*.pkg

# --------------------------------------------------
# Vercel
# --------------------------------------------------
.vercel/

# --------------------------------------------------
# Misc
# --------------------------------------------------
*.sqlite
*.db
*.DS_Store